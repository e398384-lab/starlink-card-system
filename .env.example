# StarLink Card System - Environment Variables
# Copy this file to .env and fill in your values

# ===== REQUIRED: Database Configuration =====
# For local PostgreSQL via docker-compose:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starlink

# For Supabase:
# DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres

DATABASE_URL=your_supabase_database_url_here

# ===== REDIS Configuration =====
# For local Redis via docker-compose:
# REDIS_URL=redis://:redis123@localhost:6379/0

# For Upstash:
# REDIS_URL=rediss://:password@us1-super-wombat-12345.upstash.io:6379

REDIS_URL=your_upstash_redis_url_here

# ===== SECURITY =====
# Generate a random secret key (32+ characters)
# Example: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_change_this_to_something_random

# ===== Microsoft Teams Bot (Optional) =====
# Get these from Azure Bot Registration
TEAMS_APP_ID=your_teams_app_id_here
TEAMS_APP_PASSWORD=your_teams_app_password_here

# ===== APPLICATION SETTINGS =====
HOST=0.0.0.0
PORT=10000

# ===== OPTIONAL: Local Development =====
# Only needed if using docker-compose for PostgreSQL and Redis
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=starlink
REDIS_PASSWORD=redis123

# ===== PLATFORM SETTINGS =====
# Transaction fee percentage (default 4%, 2% from each side)
PLATFORM_FEE_PERCENTAGE=4

# Default employee limit per merchant
DEFAULT_MAX_EMPLOYEES=5

# Transfer timeout in hours (default 48)
TRANSFER_TIMEOUT_HOURS=48